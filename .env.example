# ─────────────────────────────────────────────────────────────
# LINEスタンプメーカー 環境変数一覧
# 本ファイルを .env.local にコピーして値を設定してください（.env.local はGit管理外）
# Vercel では Project Settings → Environment Variables に同じキーを登録します
# ─────────────────────────────────────────────────────────────

# ── Supabase（認証・データベース・ストレージ） ──
# Supabase ダッシュボード → Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...           # anon public key（ブラウザに露出してよい）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...               # service_role key（サーバー専用の秘密情報。絶対にブラウザへ渡さない）

# ── OpenAI GPT Image（画像生成） ──
OPENAI_API_KEY=sk-...                                  # 管理者名義アカウントのAPIキー（サーバー専用）
OPENAI_IMAGE_MODEL=gpt-image-2                         # GPT Image 2に統一
OPENAI_IMAGE_QUALITY=high                              # 画像品質: high（最高品質）
OPENAI_IMAGE_SIZE=2048x2048                            # 高品質生成用。最終的に370x320へ整形

# ── メール通知（F10 追加枠申請の管理者通知 / Resend） ──
# 未設定の場合はメール送信をスキップし、サーバーログに通知内容を出力します（開発時フォールバック）
RESEND_API_KEY=re_...                                  # Resend APIキー（任意）
MAIL_FROM="LINEスタンプメーカー <noreply@example.com>"  # 送信元アドレス
ADMIN_EMAIL=admin@example.com                          # 管理者アカウントのメールアドレス（申請通知の宛先）

# ── アプリ設定 ──
NEXT_PUBLIC_APP_URL=http://localhost:3000              # アプリの公開URL（招待リンク生成に使用。Vercelでは本番URL）
CRON_SECRET=change-me-to-a-long-random-string          # 日次削除・生成復旧Cronの認証用シークレット（Vercel Cronが送るBearerと照合）

# ── 初期管理者（seed用。supabase/seed の実行時に参照） ──
ADMIN_INITIAL_EMAIL=admin@example.com                  # 初期管理者メールアドレス
ADMIN_INITIAL_PASSWORD=change-this-password            # 初期管理者パスワード（初回ログイン後に変更推奨）
ADMIN_INITIAL_NAME=管理者
